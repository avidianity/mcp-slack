# Slack tokens — provide at least one of the two.
# Bot token (xoxb-...): posting, reactions, listing, reading.
SLACK_BOT_TOKEN=
# User token (xoxp-...): edit/delete your own messages, search.
SLACK_USER_TOKEN=

# Optional: workspace / team id (T...). Only needed for org-level (Enterprise
# Grid) tokens, where it scopes workspace-wide listings to one team.
SLACK_TEAM_ID=

# Optional: comma-separated channel-ID allowlist (enforced access boundary).
SLACK_CHANNEL_IDS=

# Optional: Bearer token for the Streamable HTTP transport.
# Auto-generated (and logged to stderr) if left empty.
AUTH_TOKEN=

# Optional: default output format for tools — "toon" (default) or "json".
SLACK_MCP_DEFAULT_FORMAT=toon

# Optional (HTTP transport): comma-separated extra Host header values to accept.
# Required to enable DNS-rebinding protection on a wildcard bind (--host 0.0.0.0).
SLACK_MCP_ALLOWED_HOSTS=

# Optional (HTTP transport): comma-separated allowed Origin header values
# (for browser clients). Leave empty to skip the Origin check.
SLACK_MCP_ALLOWED_ORIGINS=
