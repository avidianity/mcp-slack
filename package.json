{
  "name": "@avidian/mcp-slack",
  "version": "0.5.0",
  "description": "TOON-first Model Context Protocol server for Slack, with dual-token auth and both stdio and Streamable HTTP transports.",
  "type": "module",
  "license": "MIT",
  "author": "avidianity",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avidianity/mcp-slack.git"
  },
  "homepage": "https://github.com/avidianity/mcp-slack#readme",
  "bugs": {
    "url": "https://github.com/avidianity/mcp-slack/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "slack",
    "toon",
    "ai",
    "llm"
  ],
  "bin": {
    "mcp-slack": "./dist/index.js"
  },
  "main": "./dist/lib.cjs",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/lib.bun.js",
      "import": {
        "types": "./dist/lib.d.ts",
        "default": "./dist/lib.js"
      },
      "require": {
        "types": "./dist/lib.d.cts",
        "default": "./dist/lib.cjs"
      },
      "default": "./dist/lib.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun run build:cli && bun run build:lib && bun run build:types",
    "build:cli": "bun build src/index.ts --outdir dist --target node",
    "build:lib": "bun build src/lib.ts --outfile dist/lib.js --target node --packages external && bun build src/lib.ts --outfile dist/lib.bun.js --target bun --packages external && bun build src/lib.ts --outfile dist/lib.cjs --target node --format cjs --packages external",
    "build:types": "dts-bundle-generator -o dist/lib.d.ts --project tsconfig.json --no-check --export-referenced-types false src/lib.ts && cp dist/lib.d.ts dist/lib.d.cts",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun test",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/web-api": "^7.18.0",
    "@toon-format/toon": "^2.3.0",
    "commander": "^15.0.0",
    "fuse.js": "^7.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
