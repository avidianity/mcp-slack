{
  "name": "@avidian/mcp-slack",
  "version": "0.2.0",
  "description": "TOON-first Model Context Protocol server for Slack, with dual-token auth and both stdio and Streamable HTTP transports.",
  "type": "module",
  "license": "MIT",
  "author": "avidianity",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avidianity/mcp-slack.git"
  },
  "homepage": "https://github.com/avidianity/mcp-slack#readme",
  "bugs": {
    "url": "https://github.com/avidianity/mcp-slack/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "slack",
    "toon",
    "ai",
    "llm"
  ],
  "bin": {
    "mcp-slack": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun test",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/web-api": "^7.18.0",
    "@toon-format/toon": "^2.3.0",
    "commander": "^15.0.0",
    "fuse.js": "^7.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
